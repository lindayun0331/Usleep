{
	"easycom": {
		"autoscan": true,
		"custom": {
			"^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue",
			"^qiun-(.*)": "@/uni_modules/qiun-data-charts/components/qiun-$1/qiun-$1.vue"
		}
	},
	"pages": [
		{
			"path": "pages/index/index"
		}
	],
	  "subPackages": [
    {
      "root": "pages/components",
      "name": "components",
      "pages": [
        {
          "path": "EquipInfo",
          "style": {
            "navigationBarTitleText": "设备消息",
            "navigationStyle": "custom",
            "navigationBarTextStyle": "white",
            "backgroundColor": "#2D1B4E"
          }
        },
		{
			"path": "UserManage",
			"style": {
			  "navigationBarTitleText": "用户消息",
			  "navigationStyle": "custom",
			  "navigationBarTextStyle": "white",
			  "backgroundColor": "#2D1B4E"
			}
		},
		{
			"path": "ReportTab",
			"style": {
			  "navigationBarTitleText": "Sleep Report",
			  "navigationStyle": "custom",
			  "navigationBarTextStyle": "white",
			  "backgroundColor": "#2D1B4E"
			}
		},
		{
			"path": "RealtimeTab",
			"style": {
			  "navigationBarTitleText": "实时体征",
			  "navigationStyle": "custom",
			  "navigationBarTextStyle": "white",
			  "backgroundColor": "#2D1B4E"
			}
		},
		{
			"path": "DateSwitcher",
			"style": {
			  "navigationBarTitleText": "日期切换",
			  "navigationStyle": "custom",
			  "navigationBarTextStyle": "white",
			  "backgroundColor": "#2D1B4E"
			}
		}
      ]
    },
	{
		"root":"pages/user",
		"name":"user",
		"pages":[
			{
				"path": "index",
				"style": {
				  "navigationBarTitleText": "用户个人",
				  "navigationStyle": "custom",
				  "navigationBarTextStyle": "white",
				  "backgroundColor": "#2D1B4E"
				}
			}
		]
	},
	{
		"root":"pages/Login",
		"name":"Login",
		"pages":[
			{
				"path": "LoginPage",
				"style": {
				  "navigationBarTitleText": "登录页面",
				  "navigationStyle": "custom",
				  "navigationBarTextStyle": "white",
				  "backgroundColor": "#2D1B4E"
				}
			}
		]
	}
  ],
	"preloadRule": {
		"pages/index/index": {
			"network": "all",
			"packages": ["pages/components"]
		}
	},
	"globalStyle": {
		"navigationBarTextStyle": "black",
		"navigationBarTitleText": "SleepCare Senior",
		"navigationBarBackgroundColor": "#eaeef5",
		"backgroundColor": "#2D1B4E"
	},
	"condition" : { //模式配置，仅开发期间生效
		"current": 0, //当前激活的模式(list 的索引项)
		"list": [
			{
				"name": "", //模式名称
				"path": "", //启动页面，必选
				"query": "" //启动参数，在页面的onLoad函数里面得到
			}
		]
	}
}
